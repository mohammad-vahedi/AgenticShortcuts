# ─── macOS junk ─────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─── Xcode build output ─────────────────────────────────────────────────────
# All of these are regenerated on every build and should never be committed.
build/
DerivedData/
*.o
*.app
*.ipa
*.dSYM.zip
*.dSYM

# ─── Xcode per-user state ───────────────────────────────────────────────────
# xcuserdata holds editor breakpoints, window layout, schemes that the user
# marked as "shared = false", etc. None of this should travel between machines.
# We keep the project file itself (AgenticShortcuts.xcodeproj/project.pbxproj)
# because it's generated by xcodegen from project.yml and Xcode users need it.
xcuserdata/
*.xcuserstate
*.xcuserdatad
*.moved-aside
*.pbxuser
!default.pbxuser

# Shared schemes you DO want committed live under
# AgenticShortcuts.xcodeproj/xcshareddata/xcschemes/ — those are explicitly
# allowed by the rules above (we only ignore the *user* xcuserdata folder).

# ─── Swift Package Manager ──────────────────────────────────────────────────
.swiftpm/
.build/
Packages/
Package.pins
*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/

# Keep Package.resolved if you add SPM deps later — it locks dependency
# versions for reproducible builds. Uncomment to ignore instead.
# Package.resolved

# ─── Carthage / CocoaPods (not used today, just in case) ────────────────────
Carthage/Build/
Pods/

# ─── Fastlane ───────────────────────────────────────────────────────────────
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# ─── Editors ────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Local Claude Code settings ─────────────────────────────────────────────
# .claude/settings.local.json holds per-clone permissions and shouldn't be
# shared. The shared .claude/settings.json (if you add one) is fine to commit.
.claude/settings.local.json

# ─── Generated shortcut output ──────────────────────────────────────────────
# CherriCompiler writes compiled .shortcut bundles into ~/Shortcuts — that's
# outside this repo so it's already untracked. Listed here only as a reminder.
# ~/Shortcuts/   (intentionally not ignored — it's outside the repo)
